# HomeTutorsWorld — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ─── EmailJS Configuration ───────────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_LEAD_TEMPLATE_ID=your_lead_template_id
VITE_EMAILJS_TUTOR_TEMPLATE_ID=your_tutor_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ─── Business Contact Details ────────────────────────────────────────────────
VITE_CONTACT_PHONE=+91 XXXXX XXXXX
VITE_CONTACT_EMAIL=your@email.com
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX
VITE_BUSINESS_NAME=HomeTutorsWorld

# ─── WhatsApp Default Message ────────────────────────────────────────────────
VITE_WHATSAPP_DEFAULT_MESSAGE=Hello HomeTutorsWorld, I would like to book a free trial class. Please help me find a suitable tutor.

# ─── Google Maps ─────────────────────────────────────────────────────────────
VITE_GOOGLE_MAP_URL=https://www.google.com/maps?q=Your+Location&output=embed
